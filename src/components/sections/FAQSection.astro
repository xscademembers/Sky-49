---
import { faqItems } from '../../data/faq';
---

<section id="faq" class="scroll-mt-24 border-t border-stone/40 bg-beige/30 py-16 md:py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <div class="mb-4 flex items-center gap-4">
        <div class="h-px w-10 bg-gold" aria-hidden="true"></div>
        <p class="text-xs font-medium uppercase tracking-[0.25em] text-muted">FAQ</p>
      </div>
      <h2 class="font-serif text-3xl text-charcoal md:text-4xl">Sky49 Hyderabad — frequently asked questions</h2>
      <p class="mt-3 text-muted">
        Ten visible Q&amp;A pairs optimized for FAQ rich results and AI citation blocks about
        <strong>Sky49 Tellapur</strong>.
      </p>
    </div>

    <div class="space-y-3">
      {
        faqItems.map((item) => (
          <details class="group rounded-xl border border-stone/50 bg-white p-5 shadow-sm open:border-gold/30">
            <summary class="cursor-pointer font-serif text-lg text-charcoal marker:text-gold">
              {item.question}
            </summary>
            <p class="mt-4 text-sm font-light leading-relaxed text-muted">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
