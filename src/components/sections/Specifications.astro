---
const specs = [
  { label: 'Structure', value: 'RCC frame engineered for high-rise performance (indicative)' },
  { label: 'Facades', value: 'Premium glazing & skyline-responsive cladding strategy' },
  { label: 'Lobbies', value: 'Double-height arrival experience with hospitality-grade finishes' },
  { label: 'Elevators', value: 'High-speed passenger lifts across residential zones' },
  { label: 'Parking', value: 'Structured parking with EV-ready provisions (subject to plan)' },
  { label: 'Security', value: 'Multi-tier access control and CCTV backbone' },
  { label: 'Sustainability', value: 'Rainwater, energy-conscious services—confirm latest green features' },
] as const;
---

<section id="specifications" class="scroll-mt-24 border-t border-stone/40 bg-beige/30 py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="mb-10 max-w-3xl">
      <div class="mb-4 flex items-center gap-4">
        <div class="h-px w-10 bg-gold" aria-hidden="true"></div>
        <p class="text-xs font-medium uppercase tracking-[0.25em] text-muted">Specifications</p>
      </div>
      <h2 class="font-serif text-3xl text-charcoal md:text-4xl">Sky49 specifications with practical clarity</h2>
      <p class="mt-4 text-muted">
        Use this section as a quick diligence snapshot for <strong>Sky49 Tellapur</strong>. Final drawings,
        brands, and compliance documents should always be validated during your site visit and official review.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-12">
      <div class="grid gap-4 sm:grid-cols-2 lg:col-span-8">
        {
          specs.map((row) => (
            <article class="group rounded-2xl border border-stone/50 bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-gold/40 hover:shadow-[var(--shadow-soft)] sm:p-6">
              <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">{row.label}</p>
              <p class="mt-3 text-sm font-light leading-relaxed text-charcoal/85">{row.value}</p>
            </article>
          ))
        }
      </div>

      <aside class="rounded-2xl border border-gold/30 bg-gradient-to-b from-white to-warm-white/95 p-6 shadow-[var(--shadow-soft)] lg:col-span-4 lg:self-start">
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">Before you finalize</p>
        <h3 class="mt-2 font-serif text-2xl text-charcoal">Diligence checklist</h3>
        <ul class="mt-5 space-y-3 text-sm font-light leading-relaxed text-muted">
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold"></span>
            Verify tower-wise drawings, floor plans, and area statements.
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold"></span>
            Confirm lift-to-unit ratio and service elevator strategy.
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold"></span>
            Check parking allocation terms and EV readiness scope.
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold"></span>
            Validate current RERA disclosures and approval milestones.
          </li>
        </ul>
      </aside>
    </div>
  </div>
</section>
