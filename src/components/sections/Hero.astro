---
import { Image } from 'astro:assets';
import { site } from '../../data/site';
---

<section
  id="hero"
  class="relative isolate min-h-[88svh] overflow-hidden scroll-mt-0"
  aria-labelledby="hero-heading"
>
  <div class="absolute inset-0">
    <Image
      src={site.heroImage.src}
      alt={site.heroImage.alt}
      width={site.heroImage.width}
      height={site.heroImage.height}
      class="h-full w-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      formats={['avif', 'webp']}
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-warm-white/95 via-warm-white/75 to-warm-white/90"
      aria-hidden="true"
    />
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_20%,rgba(201,168,106,0.18),transparent_55%)]"
      aria-hidden="true"
    />
  </div>

  <div class="relative z-10 mx-auto flex min-h-[88svh] max-w-7xl flex-col justify-end px-4 pb-16 pt-28 sm:px-6 lg:px-10 lg:pb-24 lg:pt-32">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-7">
        <p
          class="mb-4 text-xs font-medium uppercase tracking-[0.35em] text-muted"
          id="hero-eyebrow"
        >
          Ultra-luxury branded residences · Hyderabad
        </p>
        <h1
          id="hero-heading"
          class="editorial-h1 mb-6 max-w-4xl text-4xl leading-[1.08] sm:text-5xl md:text-6xl lg:text-[3.5rem] lg:leading-[1.05]"
        >
          Sky49 Tellapur — Ultra-Luxury 3 &amp; 4 BHK Apartments in Osman Nagar, Hyderabad
        </h1>
        <p class="max-w-2xl text-lg font-light leading-relaxed text-muted sm:text-xl">
          G+49 floors • 4 towers • 1 lakh+ sq ft amenities • RERA approved
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="#contact"
            class="inline-flex items-center justify-center rounded-full bg-charcoal px-8 py-4 text-center text-xs font-semibold uppercase tracking-[0.2em] text-white shadow-lg transition hover:bg-gold hover:text-charcoal"
          >
            Enquire Now
          </a>
          <a
            href="#contact"
            class="glass-panel inline-flex items-center justify-center rounded-full px-8 py-4 text-center text-xs font-semibold uppercase tracking-[0.2em] text-charcoal transition hover:border-gold/60"
          >
            Download Brochure
          </a>
        </div>
        <p class="mt-8 max-w-xl text-sm font-light leading-relaxed text-muted">
          Sky49 Hyderabad combines Tellapur’s greenfield calm with elite connectivity—crafted for founders,
          CXOs, and families who want a brighter, editorial home with enduring asset quality.
        </p>
      </div>

      <div class="lg:col-span-5">
        <div
          class="glass-panel gold-shimmer relative overflow-hidden rounded-3xl p-6 shadow-[var(--shadow-soft)] sm:p-8"
        >
          <div class="pointer-events-none absolute -right-8 -top-8 h-40 w-40 rounded-full bg-gold/20 blur-3xl" />
          <p class="font-serif text-3xl leading-[1.15] text-charcoal">Request a EOI</p>
          <p class="mt-2 text-sm text-muted sm:text-base">Enter before the address appreciates.</p>

          <form class="mt-6 space-y-4" aria-label="Hero EOI form">
            <label class="sr-only" for="hero-eoi-name">Your Name</label>
            <input
              id="hero-eoi-name"
              name="name"
              type="text"
              placeholder="Your Name"
              class="w-full rounded-none border border-stone/50 bg-white/70 px-4 py-3 text-sm text-charcoal placeholder:text-muted focus:border-gold focus:outline-none"
              autocomplete="name"
            />

            <label class="sr-only" for="hero-eoi-phone">Phone Number</label>
            <input
              id="hero-eoi-phone"
              name="phone"
              type="tel"
              placeholder="Phone Number"
              class="w-full rounded-none border border-stone/50 bg-white/70 px-4 py-3 text-sm text-charcoal placeholder:text-muted focus:border-gold focus:outline-none"
              autocomplete="tel"
            />

            <a
              href="#contact"
              class="inline-flex w-full items-center justify-between bg-charcoal px-6 py-4 text-sm font-semibold text-white transition hover:bg-gold hover:text-charcoal"
            >
              <span>Register EOI Now</span>
              <span aria-hidden="true">-&gt;</span>
            </a>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
